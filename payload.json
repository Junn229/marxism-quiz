{"owner": "Junn229", "repo": "marxism-quiz", "branch": "main", "message": "Initial commit: 马克思主义原理题库答题网页", "files": [{"path": "index.html", "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>马克思主义基本原理 · 题库练习</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nbody{font-family:-apple-system,BlinkMacSystemFont,\"PingFang SC\",\"Microsoft YaHei\",sans-serif;background:#f0f2f5;color:#333;min-height:100vh}\n.container{max-width:800px;margin:0 auto;padding:16px}\n.header{background:linear-gradient(135deg,#c62828,#d32f2f);color:#fff;padding:28px 20px;border-radius:12px;margin-bottom:20px;text-align:center;box-shadow:0 2px 12px rgba(198,40,40,.3)}\n.header h1{font-size:22px;margin-bottom:6px}\n.header p{font-size:13px;opacity:.9}\n.stats-bar{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap}\n.stat-card{flex:1;min-width:80px;background:#fff;border-radius:10px;padding:14px 10px;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,.06)}\n.stat-card .num{font-size:26px;font-weight:700}\n.stat-card .label{font-size:12px;color:#888;margin-top:2px}\n.stat-card.correct .num{color:#2e7d32}\n.stat-card.wrong .num{color:#c62828}\n.stat-card.total .num{color:#1565c0}\n.stat-card.score .num{color:#e65100}\n.controls{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center}\n.controls select,.controls button{padding:8px 14px;border-radius:8px;border:1px solid #d0d5dd;font-size:13px;cursor:pointer;background:#fff}\n.controls button{background:#c62828;color:#fff;border-color:#c62828;font-weight:600}\n.controls button:hover{background:#b71c1c}\n.controls button.secondary{background:#fff;color:#c62828;border-color:#c62828}\n.controls button.secondary:hover{background:#fff5f5}\n.controls .mode-toggle{display:flex;border-radius:8px;overflow:hidden;border:1px solid #d0d5dd}\n.controls .mode-toggle button{border-radius:0;border:none;border-right:1px solid #d0d5dd}\n.controls .mode-toggle button:last-child{border-right:none}\n.controls .mode-toggle button.active{background:#c62828;color:#fff}\n.progress-wrap{background:#fff;border-radius:10px;padding:12px 16px;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,.06)}\n.progress-wrap .top{display:flex;justify-content:space-between;font-size:13px;color:#666;margin-bottom:6px}\n.progress-bar{height:6px;background:#e0e0e0;border-radius:3px;overflow:hidden}\n.progress-bar .fill{height:100%;background:linear-gradient(90deg,#c62828,#ef5350);border-radius:3px;transition:width .3s}\n.q-card{background:#fff;border-radius:12px;padding:24px 20px;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,.06)}\n.q-card .q-meta{font-size:12px;color:#999;margin-bottom:8px;display:flex;gap:10px}\n.q-card .q-meta .badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px}\n.q-card .q-meta .badge.single{background:#e3f2fd;color:#1565c0}\n.q-card .q-meta .badge.multi{background:#fff3e0;color:#e65100}\n.q-card .q-stem{font-size:16px;line-height:1.7;margin-bottom:16px;font-weight:500}\n.q-card .q-options{display:flex;flex-direction:column;gap:8px}\n.q-card .q-option{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border:2px solid #e8e8e8;border-radius:10px;cursor:pointer;transition:all .15s;font-size:14px;line-height:1.6}\n.q-card .q-option:hover{border-color:#c62828;background:#fff5f5}\n.q-card .q-option .opt-label{flex-shrink:0;width:28px;height:28px;border-radius:50%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#666;transition:all .15s}\n.q-card .q-option.selected{border-color:#c62828;background:#fff5f5}\n.q-card .q-option.selected .opt-label{background:#c62828;color:#fff}\n.q-card .q-option.correct-ans{border-color:#2e7d32;background:#e8f5e9}\n.q-card .q-option.correct-ans .opt-label{background:#2e7d32;color:#fff}\n.q-card .q-option.wrong-ans{border-color:#c62828;background:#ffebee}\n.q-card .q-option.wrong-ans .opt-label{background:#c62828;color:#fff}\n.q-card .q-option.disabled{pointer-events:none;opacity:.8}\n.q-card .q-option.disabled:not(.correct-ans):not(.wrong-ans){opacity:.5}\n.q-card .q-feedback{margin-top:14px;padding:14px;border-radius:8px;font-size:14px;line-height:1.7;display:none}\n.q-card .q-feedback.show{display:block}\n.q-card .q-feedback.correct{background:#e8f5e9;border-left:4px solid #2e7d32;color:#1b5e20}\n.q-card .q-feedback.wrong{background:#ffebee;border-left:4px solid #c62828;color:#b71c1c}\n.q-card .q-feedback .exp-title{font-weight:700;margin-bottom:4px}\n.q-card .q-submit{margin-top:14px;text-align:center}\n.q-card .q-submit button{padding:10px 36px;border-radius:8px;border:none;background:#c62828;color:#fff;font-size:15px;font-weight:600;cursor:pointer}\n.q-card .q-submit button:hover{background:#b71c1c}\n.q-card .q-submit button:disabled{background:#ccc;cursor:not-allowed}\n.nav-row{display:flex;gap:10px;justify-content:center;margin-bottom:20px}\n.nav-row button{padding:10px 24px;border-radius:8px;border:1px solid #d0d5dd;background:#fff;font-size:14px;cursor:pointer}\n.nav-row button:hover{background:#f5f5f5}\n.nav-row button:disabled{opacity:.4;cursor:not-allowed}\n.review-panel{background:#fff;border-radius:12px;padding:20px;margin-top:20px;box-shadow:0 1px 4px rgba(0,0,0,.06)}\n.review-panel h3{margin-bottom:14px;font-size:16px}\n.review-item{padding:12px;border:1px solid #e8e8e8;border-radius:8px;margin-bottom:8px;cursor:pointer;font-size:14px}\n.review-item:hover{background:#fafafa}\n.review-item .q-num{color:#c62828;font-weight:700}\n.review-item .q-correct{color:#2e7d32;margin-left:8px}\n.empty-state{text-align:center;padding:40px 20px;color:#999}\n@media(max-width:600px){.header h1{font-size:18px}.stat-card .num{font-size:22px}.q-card .q-stem{font-size:15px}}\n</style>\n</head>\n<body>\n<div class=\"container\">\n<div class=\"header\"><h1>马克思主义基本原理 · 题库练习</h1><p>共 86 题 | 单选题 + 多选题 | 即时判分 | 支持键盘方向键</p></div>\n<div class=\"stats-bar\">\n<div class=\"stat-card total\"><div class=\"num\" id=\"stat-total\">0</div><div class=\"label\">已答</div></div>\n<div class=\"stat-card correct\"><div class=\"num\" id=\"stat-correct\">0</div><div class=\"label\">正确</div></div>\n<div class=\"stat-card wrong\"><div class=\"num\" id=\"stat-wrong\">0</div><div class=\"label\">错误</div></div>\n<div class=\"stat-card score\"><div class=\"num\" id=\"stat-score\">-</div><div class=\"label\">正确率</div></div>\n</div>\n<div class=\"controls\">\n<select id=\"section-filter\"><option value=\"all\">全部章节</option></select>\n<div class=\"mode-toggle\">\n<button id=\"btn-sequential\" class=\"active\">顺序答题</button>\n<button id=\"btn-random\">随机出题</button>\n</div>\n<button class=\"secondary\" id=\"btn-review\">错题回顾</button>\n<button class=\"secondary\" id=\"btn-reset\">重置进度</button>\n</div>\n<div class=\"progress-wrap\">\n<div class=\"top\"><span id=\"progress-text\">第 0/0 题</span><span id=\"progress-pct\">0%</span></div>\n<div class=\"progress-bar\"><div class=\"fill\" id=\"progress-fill\" style=\"width:0%\"></div></div>\n</div>\n<div id=\"question-area\"></div>\n<div class=\"nav-row\">\n<button id=\"btn-prev\" disabled>← 上一题</button>\n<button id=\"btn-next\" disabled>下一题 →</button>\n</div>\n<div class=\"review-panel\" id=\"review-panel\" style=\"display:none\">\n<h3>📋 错题本</h3>\n<div id=\"review-list\"></div>\n<div class=\"empty-state\" id=\"review-empty\">暂无错题，继续保持！</div>\n</div>\n</div>\n<script>\nvar ALL_Q = [{\"id\": 1, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 1, \"stem\": \"作为中国共产党和社会主义事业指导思想的马克思主义是指（\", \"options\": {\"A\": \"中国化的马克思主义\", \"B\": \"马克思恩格斯以及列宁学说的体系和中国化的马克思主义\", \"C\": \"马克思恩格斯创立的基本理论、基本观点和学说的体系\", \"D\": \"马克思恩格斯和列宁的学说体系\"}, \"answer\": \"B\", \"explanation\": \"此题考查的知识点是作为中国共产党和社会主义事业指导思想的马克思主义的含义。中国共产党的指导思想是广义的马克思主义，包括：马克思恩格斯的基本理论、观点方法；列宁的继承和发展；毛泽东思想和中国特色社会主义理论体系即中国化的马克思主义。显然B是最全面的答案。\"}, {\"id\": 2, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 2, \"stem\": \"马克思主义产生的经济社会条件是（）。\", \"options\": {\"A\": \"资本主义固有矛盾的发展\", \"B\": \"资本主义生产力和生产关系之间的矛盾\", \"C\": \"工人阶级与资本家阶级之间的阶级矛盾的加剧\", \"D\": \"社会化大生产同生产资料资本家私人占有之间的矛盾的激化\"}, \"answer\": \"A\", \"explanation\": \"此题考查的知识点是马克思主义产生的经济、社会历史条件。资本主义固有矛盾的发展，为马克思主义的产生提供了经济社会的条件和基础。选项BCD都是选项A的内容展开，所以正确的选项为AO0思想政治工亻乍人员晋升职称政氵台理论考试复习材料000应马克思主义最重要的理论品质是（A.吐故纳新B.科学严谨〖答案]DC.博大精深坚持一切从实际出发，理论联系实际，实事求是，在实践中检验真理和发展真理，是马克思主义最重要的理论品质。这种与时俱进的理论品质是160多年来马克思主义始终保持蓬勃生命力的关键所在。这种品质是马克思主义理论本质的反映，是人类认识发展规律的具体体现，是理论创新的内在要求。“马克思主义具有与时俱进的理论品质”，这是江泽民同志在庆祝中国共产党成立80周年大会上的重要讲话中所作出的一个极其重要的科学论断。这个论断既是马克思主义诞生以来160多年历史经验的科学总结，又有鲜明的现实针对性和理论意义。这一科学论断突出地强调了马克思主义是伴随着时代、形势的发展而发展的，是一个对马克思主义科学性的新概括。马克思主义这种与时俱进的理论品质是通过两种基本的形式表现出来的。第一种形式，是后人与时俱进，对前人的\"}, {\"id\": 3, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 4, \"stem\": \"马克思主义哲学解决哲学基本问题的出发点是〈）。\", \"options\": {\"A\": \"物质第一性，精神第二性\", \"B\": \"理论和实践的关系\", \"C\": \"实践\", \"D\": \"自然和社会的关系\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 4, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 5, \"stem\": \"马克思把黑格尔的辩证法称为（\", \"options\": {\"A\": \"“合理内核”\", \"B\": \"“基本内核”\", \"C\": \"精髓\", \"D\": \"核」心\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 5, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 6, \"stem\": \"马克思主义产生以前，长期占统治地位的历史观是（）。\", \"options\": {\"A\": \"唯物史观\", \"B\": \"唯心史观\", \"C\": \"激变论\", \"D\": \"庸俗进化论\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 6, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 7, \"stem\": \"马克思主义产生的经济社会历史条件是（）。\", \"options\": {\"A\": \"无产阶级作为独立的政治力量登上历史舞台\", \"B\": \"马克思、恩格斯完成了世界观的转变\", \"C\": \"马克思、恩格斯汲取了人类文明的优秀成果\", \"D\": \"资本主义社会的发展和基本矛盾的显现\"}, \"answer\": \"D\", \"explanation\": \"马克思主义的产生，是众多因素合力促成的结果。A项是马克思主义产生的现实需要；B项是马克思主义产生的主观条件；C项是马克思主义的理论来源。只有D项契合题干的设问。\"}, {\"id\": 7, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 8, \"stem\": \"马克思主义产生的现实需要是（）。\", \"options\": {\"A\": \"无产阶级作为独立的政治力量登上历史舞台\", \"B\": \"马克思、恩格斯完成了世界观和阶级立场的转变\", \"C\": \"马克思、恩格斯汲取了人类文明的优秀成果\", \"D\": \"资本主义社会的相当发展和基本矛盾的显现\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 8, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 9, \"stem\": \"马克思从资产阶级古典政治经济学家那里继承的最重要的思想是（）。\", \"options\": {\"A\": \"唯物论\", \"B\": \"辩证法\", \"C\": \"劳动价值论\", \"D\": \"剩余价值学说\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 9, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 10, \"stem\": \"马克思主义的阶级基础是（）。\", \"options\": {\"A\": \"无产阶级反对资产阶级的斗争\", \"C\": \"无产阶级\", \"D\": \"无产阶级政党\"}, \"answer\": \"C\", \"explanation\": \"&工农联盟D.无产阶级政党A是马克思主义产生的实践基础；B是无产阶级专政的阶级基础；D是无产阶级革命的领导力量。\"}, {\"id\": 10, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 11, \"stem\": \"马克思主义中国化的本质是（）。\", \"options\": {\"A\": \"马克思主义科学性的体现\", \"B\": \"一个以中国国情为基础的全新理论\", \"C\": \"用现成的马克思主义理论直接解答、解决中国的现实问题\", \"D\": \"用马克思主义基本理论指导中国革命和建设，并在这个过程中发展马克思主义\"}, \"answer\": \"D\", \"explanation\": \"此题考查的知识点是马克思主义在实践中的发展。马克思主义中国化的本质就是要考虑中国革命和建设的特殊性，用马克思主义基本理论指导中国革命和建设，在这个过程中发展马克思主义、与时俱进。选项A不够准确，选项BC本身错误，所以正确答案是DO\"}, {\"id\": 11, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 12, \"stem\": \"马克思主义最根本的世界观和方法论是（）。\", \"options\": {\"A\": \"辩证唯物主义和历史唯物主义\", \"B\": \"唯物论和辩证法\", \"C\": \"科学社会主义\", \"D\": \"政治经济学\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 12, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 13, \"stem\": \"马克思主义最鲜明的政治立场是（）·\", \"options\": {\"A\": \"推翻资本主义社会\", \"B\": \"建立无产阶级专政\", \"C\": \"建立生产资料公有制\", \"D\": \"致力于实现最广大人民的根本利益\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 13, \"section\": \"马克思主义基本原理\", \"type\": \"单选题\", \"number\": 14, \"stem\": \"马克思主义最崇高的社会理想是（）。\", \"options\": {\"A\": \"推翻资本主义社会\", \"B\": \"实现共产主义社会\", \"C\": \"建立生产资料公有制\", \"D\": \"建立无产阶级专政\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 14, \"section\": \"马克思主义基本原理\", \"type\": \"多选题\", \"number\": 1, \"stem\": \"作为一个完整的科学体系》马克思主义理论体系的三个组成部分是（卜？0。\", \"options\": {\"A\": \"马克思主义政治学\", \"B\": \"马克思主义政治经济学\", \"C\": \"马克思主义哲学\", \"D\": \"科学社会主义\"}, \"answer\": \"BCD\", \"explanation\": \"\"}, {\"id\": 15, \"section\": \"马克思主义基本原理\", \"type\": \"多选题\", \"number\": 2, \"stem\": \"国古典哲学、英国古典政治经济学和法国、英国空想社会主义是马克思主义直接的理论来源。属于德国古典哲学、英国古典政治经济学和法国、英国空想社会主义代表人物的有（）。\", \"options\": {\"A\": \"苏格拉底和托马斯·莫尔\", \"B\": \"圣西门和傅立叶\", \"C\": \"黑格尔和费尔巴哈\", \"D\": \"亚当．斯密和大卫．李嘉图\"}, \"answer\": \"BCD\", \"explanation\": \"\"}, {\"id\": 16, \"section\": \"马克思主义基本原理\", \"type\": \"多选题\", \"number\": 3, \"stem\": \"马克思、恩格斯之所以能鸲实现社会主义思想从空想到科学的飞跃，是因为他们独创了（\", \"options\": {\"A\": \"劳动价值论\", \"B\": \"剩余价值学说\", \"C\": \"历史唯物主义\", \"D\": \"辩证法\"}, \"answer\": \"BC\", \"explanation\": \"\"}, {\"id\": 17, \"section\": \"马克思主义基本原理\", \"type\": \"多选题\", \"number\": 4, \"stem\": \"马克思主义的科学性和革命性可以概括为（\", \"options\": {\"A\": \"辩证唯物主义和历史唯物主义是马克思主义最根本的世界观和方法论\", \"B\": \"最广大人民的根本利益是马克思主义最鲜明的政治立场\", \"C\": \"一切从实际出发，实事求是，在实践中检验和发展真理是马克思主义最重要的理论品质\", \"D\": \"实现共产主义是马克思主义最崇高的社会理想\"}, \"answer\": \"ABCD\", \"explanation\": \"我们坚持马克思主义的基本立场、基本观点和基本方法，就是要辩证唯物主义和历史唯物主义的世界观和方法论，即马克思主义哲学，坚持实现最广大人民的根本利益的政治立场，坚持一切从实际出发，实事求是，在实践中检验真理和发展真理，把握和顺应人类社会发展的客观规律，不断推进中国特色社会主义事业的发展，、为实现共产主义的崇高社会理想而奋斗。马克思主义哲学是无产阶级科学的世界观和方法论，马克思、下篇练习题恩格斯在实践的基础上创立了马克思主义哲学，它的全部理论来自于实践，又经过实践的检验，所以我们说它的理论具有科学性。故选项A应选。马克思主义是在无产阶级革命实践中产生、发展起来的，是无产阶级根本利益的科学表现。马克思主义是“改变世界”的科学、指导全人类解放的科学。如果说无产阶级是人类解放的“心脏”，那么马克思主义就是人类解放的“头脑\\\"。这说明马克思主义具有革命性。故选项B应选。选项C说的是马克思主义与时俱进的理论品质，与时俱进的理论品质是马克思主义始终保持生命力的关键所在，这种属性是马克思主义理论本质的反映，马克思主义理论的本质属性就在于它的彻底的科学性、坚定的革命性和自觉的实践性，而彻底的科学性是最根本的\"}, {\"id\": 18, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 1, \"stem\": \"恩格斯第一次明确指出：全部哲学，特别是近代哲学的重大的基本问题是\", \"options\": {\"A\": \"哲学与人类的关系问题\", \"B\": \"人与自然界的关系问题\", \"C\": \"思维和存在的关系问题\", \"D\": \"主体和客体的关系问题\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 19, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 2, \"stem\": \"根据对哲学基本问题第一方面的回答，哲学可分为（\", \"options\": {\"A\": \"唯物主义和唯心主义\", \"B\": \"可知论和不可知论\", \"C\": \"辩证法和形而上学\", \"D\": \"唯物史观和唯心史观\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 20, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 3, \"stem\": \"在唯物主义发展过程中，出现了三种基本形态：朴素唯物主义、形而上学唯物主义和辩证唯物主义。以下哪项是区分唯物主义三种形态的重要依据（）·\", \"options\": {\"A\": \"一元论还是二元论\", \"B\": \"世界是否统一于物质\", \"C\": \"世界是否可知\", \"D\": \"对物质认识的不同深度和广度\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 21, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 4, \"stem\": \"有一副对联，上联是“橘子洲，洲旁舟，舟行洲不行”；下联是“天心阁，阁中鸽，鸽飞阁不飞”。这形象地说明了运动和静止是相互依存的，静止是（）·\", \"options\": {\"A\": \"运动的普遍状态\", \"B\": \"运动的内在原因\", \"C\": \"运动的衡量尺度\", \"D\": \"运动的存在方式\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 22, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 5, \"stem\": \"“对事物从客体的或直观的形式去理解，而不是把它们当做人的感性活动，当做实践去理解。\\\"这是（）。\", \"options\": {\"A\": \"客观唯心主义的观点\", \"C\": \"辩证唯物主义的观点\", \"D\": \"形而上学唯物主义的观点\"}, \"answer\": \"D\", \"explanation\": \"&主观唯心主义的观点D.形而上学唯物主义的观点此题考查的知识点是形而上学唯物主义。题干中的这句话出自马克思的《关于费尔巴哈的提纲》。“从客体的或直观的形式去理解”即不从实践的角度、主体的角度去理解现实，不理解主体人在实践活动、认识活动中的能动性。这是形而上学唯物主义的观点。所以本题的正确选项是D。\"}, {\"id\": 23, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 6, \"stem\": \"“理在事先。”这一观点属于（）。\", \"options\": {\"A\": \"辩证唯物主义\", \"B\": \"历史唯物主义\", \"C\": \"主观唯心主义\", \"D\": \"客观唯心主义·\"}, \"answer\": \"D\", \"explanation\": \"此题考查的知识点是客观唯心主义。客观唯心主义认为世界的本原是人之外的某种神秘莫测的精神力量，其常用“理”“理念”和“绝对精神”来表述。本题中的“理”便属于客观精神。所以本题的正确选项是D。\"}, {\"id\": 24, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 7, \"stem\": \"宋朝画家文与可的住宅周围有很多竹子。他一年四季注意观察竹子的变化，对竹子的形状，姿态有着透彻的了解，因而画出的竹子生动逼真。有诗人称赞他：“与可画竹时，胸中有成竹。”这一事实体现的哲学道理是（）。\", \"options\": {\"A\": \"意识是物质长期发展的产物\", \"B\": \"意识是人脑的机能\", \"C\": \"意识是对客观世界的反映\", \"D\": \"物质具有不依赖于意识的客观实在性\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是意识的能动作用。从题干中可以看出，文与可之所以能画出生动逼真的竹子，是他长期观察，对竹子有透彻理解的结果。这说明人脑不会自动产生意识，只有当客观事物作用于人的感觉器官，并反映到人脑之后，才能形成意识，也就是说，意识是对客观世界的能动反映。A项是意识的起源，B项是意识的本质，D项是物质的特性，均不符合。正确答案是co\"}, {\"id\": 25, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 8, \"stem\": \"休谟说：“感觉是人和世界之间的屏障。”这一观点是（）·\", \"options\": {\"A\": \"唯心主义的观点\", \"B\": \"辩证法的观点\", \"C\": \"可知论的观点\", \"D\": \"不可知论的观点\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 26, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 9, \"stem\": \"哲学中的物质范畴是对物质世界多样性和统一性所作的最高概括。自然科学中具体的物质形态和物质结构随着科学的发展而不断变化，但无论出现怎样的情形，都不可能改变马克思主义哲学关于物质范畴的唯一特性。物质的唯一特性是（）。\", \"options\": {\"A\": \"运动性\", \"B\": \"客观实在性\", \"C\": \"时空特性\", \"D\": \"可知性\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 27, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 10, \"stem\": \"“世界上除了运动着的物质之外，什么也没有\\\"》这是（）。一33一\", \"options\": {\"A\": \"否认精神性存在的唯心主义观点\", \"B\": \"主张世界统一于物质的辩证唯物主义观点\", \"C\": \"否认静止的诡辩论观点\", \"D\": \"把人的意识铧成某种特殊的“精细物质”的机械唯物主义观点\"}, \"answer\": \"B\", \"explanation\": \"此题考查的知识点是世界的物质统一性。列宁提出：“世界上除了运动着的物质，什么也没有，而运动着的物质只有在空间和时间中运动。”列宁的这句话说明，世界上的一切事物和现象，包括意识现象，归根到底都是物质的表现形态；世界上的一切变化和发展，其原因都在于物质世界自身，即世界是多样性的物质统一。所以，本题的正确选项是BO11·马克思指出：“观念的东西不外是移入人的头脑并在人的头脑中改造过的物质的东西而已。\\\"这表明（A.意识是客观存在的主观映像B.人脑是意识的源泉C.意识是人脑分泌出来的D.观念的东西和物质的东西没有本质区别〖答案〗A此题考查的知识点是意识的本质。题干中“移人”“改造”“物质”几个关键词，说明物质决定意识，意识是人脑对物质的能动反映。意识的内容是客观的，形式是主观的，是客观内容和主观形式的有机统一。A选项正确。选项B属于唯心主义的观点，正确说法是“实践是认识的来源\\\"；选项c是恩格斯当年批评过的庸俗唯物主义观点；D选项不是马克思主义的观点。\"}, {\"id\": 28, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 12, \"stem\": \"对物质和物质具体形态之间关系表述正确的是（）。\", \"options\": {\"A\": \"第一性和第二性的关系\", \"C\": \"整体和部分的关系\", \"D\": \"具体和抽象的关系\"}, \"answer\": \"B\", \"explanation\": \"&共性和个性的关系D.具体和抽象的关系此题考查的知识点是物质和物质具体形态的关系。物质的具体形态由于自然界物质运动的形式及结构功能不同，其表现形态是无限多样和不可穷尽的。在物质世界中，每一个具体的物质形态都有自己的规定性，都有自己特殊的质，彼此有别，由此形成物质世界的多样性。物质概念抽象的是物质具体形态的共性，即物质是从万事万物中概括抽象出来的，物质存在于具体物质形态中，而物质的具体形态是物质的具体表现，二者之间是共性与个性的关系，抽象与具体的关系。正确答案是BO选项D顺序说反了，应为抽象和具体的关系，与题干物质和物质的具体形态呼应。\"}, {\"id\": 29, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 13, \"stem\": \"相对论原理证明，物质的质量与能量的统一是可以计算的，时空的性质不仅取决一34．于物质的运动，而且更重要的是取决于物质分布本身。这说明（\", \"options\": {\"A\": \"主观的时空观念必然是空洞的抽象\", \"B\": \"时空可以脱离物质而存在\", \"C\": \"时空只是物质存在的形式\", \"D\": \"物质运动是时空的形式\"}, \"answer\": \"C\", \"explanation\": \"解析此题考查的知识点是时空是物质运动的存在形式。相对论原理说明：时空不能离开物质而存在，必须依赖于物质才有意义，时空是物质运动的存在形式。选项B不符合题意；选项D颠倒了物质运动和时空的关系；选项A与此题无关，所以本题选\"}, {\"id\": 30, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 14, \"stem\": \"人在心情愉快时，会感到“光阴似箭”．心情抑郁时，则感到“度日如年\\\"。这表明（\", \"options\": {\"A\": \"时间是人在主观上的感觉\", \"B\": \"人们的时间观念具有可变性\", \"C\": \"时间具有不可知性\", \"D\": \"时间随人的感觉的变化而变化\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 31, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 15, \"stem\": \"20世纪70年代，印度发现了脱离人类社会而由狼抚育并与狼共同生活的“狼孩”。科学家发现，“狼孩\\\"没有意识，这一事实说明意识的产生（）。\", \"options\": {\"A\": \"不仅是自然界长期发展的产物，而且是社会的产物\", \"B\": \"不仅是物质现象而且是社会现象\", \"C\": \"是社会的产物，而不是自然界发展的产物\", \"D\": \"不仅反映自然界而且反映社会\"}, \"answer\": \"A\", \"explanation\": \"此题考查的知识点是人类意识的起源和本质。从意识的起源来看，意识是物质世界高度发展的产物，它既是自然界长期发展的产物，又是社会的直接产物。在意识的产生过程中，，起了决定性作用。劳动为意识的产生提供了客观的需要和可能，而劳动一开始就是社会性的活动。社会性的劳动促使了语言的产生，语言的产生对于意识的形成具有决定意义。狼孩没有意识正说明了这一点。正确答案是AO\"}, {\"id\": 32, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 16, \"stem\": \"“动中有静，静中有动\\\"包含的哲学道理是（）。\", \"options\": {\"A\": \"运动和静止的辩证统一\", \"B\": \"物质和运动的辩证统一\", \"C\": \"形而上学和诡辩论的统一\", \"D\": \"唯物论和辩证法的统一\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 33, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 17, \"stem\": \"在实践的基本形式中，最终起决定作用的是（）·\", \"options\": {\"A\": \"物质生产劳动\", \"B\": \"政治实践\", \"C\": \"处理社会关系的实践\", \"D\": \"科学实验\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 34, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 18, \"stem\": \"在马克思主义看来，实践是（）。\", \"options\": {\"A\": \"人们社会生活中的一切活动\", \"B\": \"人们能动地认识世界的精神活动\", \"C\": \"人能适应夕卜界环境的本能活动\", \"D\": \"人们能动地改造世界的客观物质性活动\"}, \"answer\": \"D\", \"explanation\": \"〔解析此题考查的知识点是实践的本质含义。马克思主义认为：实践是人类能动地改造世界的客观物质性活动。由此看来，选项A的外延过大，选项BC与马克思主义的实践观不符。所以本题的正确选项为DO\"}, {\"id\": 35, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 19, \"stem\": \"一些地方的人们掠夺性的滥挖草原上的干草，以获得一定的经济效益，却破坏了草原植被，造成土地沙漠化，一遇到大风》沙尘暴铺天盖地，给人们带来巨大灾难，这些挖甘草的人们（\", \"options\": {\"A\": \"只看到事物的客观性，没有看到人们的主观能动性\", \"B\": \"只看到事物的绝对运动，没有看到事物的相对静止\", \"C\": \"只看到眼前的直接联系，没有看到长远的间接联系\", \"D\": \"只看到物与物之间的联系，没有看到人与人之间的联系\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是联系的多样性。宇宙间的一切事物都处于普遍联系之中，这要求我们必须从事物固有的联系出发，对多种联系进行具体分析，用以指导我们的实践。人们只要眼前的经济利益，说明看到了直接联系；不顾破坏生态环境带来的危害，说明人们忽视了间接联系，所以正确答案是co选项ABD均为相近的迷惑项，都不符合题意。\"}, {\"id\": 36, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 20, \"stem\": \"马克思主义的活的灵魂是（\", \"options\": {\"A\": \"实事求是\", \"B\": \"矛盾分析法\", \"C\": \"唯物史观\", \"D\": \"具体问题具体分析·\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 37, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 21, \"stem\": \"“燕子低飞蛇过道，必有大雨到\\\"这句吾包含的主要哲学道理是（）·\", \"options\": {\"A\": \"世界是普遍联系的\", \"B\": \"世界是永恒发展的\", \"C\": \"世界是物质的\", \"D\": \"矛盾具有普遍性解析]此题考查的知识点是事物的普遍联系。题干谚语说的是燕子、蛇的活动方式与气象变化之间的联系，显然，其说明的是世界是普遍联系的（A）。选项BD与题干内容无关。选项C不够准确。所以，最能说明题意的是选项A\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 38, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 22, \"stem\": \"“沉舟侧畔千帆过，病树前头万木春。”“芳林新叶催陈叶，流水前波让后波£'这两句诗包含的哲学道理是（）·\", \"options\": {\"A\": \"矛盾是事物发展的动力\", \"B\": \"事物是本质和现象的统一\", \"C\": \"事物的发展是量变和质变的统一\", \"D\": \"新事物代替旧事物是事物发展的总趋势\"}, \"answer\": \"D\", \"explanation\": \"此题考查的知识点是发展的实质。发展是新事物的产生和旧事物的灭亡。新事物必然战胜旧事物，这是由新事物的本质特点和事物发展的辩证本性决定的。就本题来说，四个选项全部正确，但最能体现这两首诗的最佳选项是D。因为“沉舟”和“病树”“陈叶”和“后波”都是旧事物的代表，而“千帆过”和“万木春”“新叶”和“前波”则代表新事物的发展趋势，所以本题选D。\"}, {\"id\": 39, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 23, \"stem\": \"唯物辩证法的实质和核心是（）。\", \"options\": {\"A\": \"对立统一规律\", \"B\": \"质量互变规律\", \"C\": \"否定之否定规律\", \"D\": \"联系和发展\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 40, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 24, \"stem\": \"矛盾的两种基本属性是（）·\", \"options\": {\"A\": \"普遍性和特殊性\", \"B\": \"同一性和斗争性\", \"C\": \"对抗性和非对抗性\", \"D\": \"可知性和不可知性\"}, \"answer\": \"B\", \"explanation\": \"（解析此题考查的知识点是矛盾及其同一性和斗争性。矛盾就是对立统一，就是同一．思想政治工作人员晋升职称政氵台理论考试复习材料00E的性和斗争性的关系，同一性和斗争性是矛盾的基本属性。所以本题的正确选项是BO\"}, {\"id\": 41, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 25, \"stem\": \"在自然界，没有上，就无所谓下；在社会中，没有先进，就无所谓落后；在认识中，没有正确，就无所谓错误。这说明（\", \"options\": {\"A\": \"矛盾双方是互相排斥的\", \"B\": \"矛盾双方是相互渗透的\", \"C\": \"矛盾双方是相互依存的\", \"D\": \"矛盾双方是相互转化的\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 42, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 26, \"stem\": \"'居安思危'这句成讠吾体现的哲学道理是（）。\", \"options\": {\"A\": \"矛盾双方在一定条件下可以互相转化\", \"B\": \"矛盾既具有普遍性又具有特殊性\", \"C\": \"内因和外因共同作用下推动事物的发展\", \"D\": \"事物发展是量变和质变的统一\"}, \"answer\": \"A\", \"explanation\": \"此题考查的知识点是矛盾的同一性。“安”与“危”作为对立着的双方，在一定条件下互相转化。所以本题的正确选项是AO\"}, {\"id\": 43, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 27, \"stem\": \"毛泽东在《矛盾论》中认为，矛盾问题的精髓是（）。\", \"options\": {\"A\": \"矛盾的同一性和斗争性的关系\", \"C\": \"矛盾普遍性和特殊性的辩证关系\", \"D\": \"内因和外因的关系\"}, \"answer\": \"C\", \"explanation\": \"B，主要矛盾和次要矛盾的关系D.内因和外因的关系此题考查的知识点是矛盾问题的精髓。矛盾问题的精髓就是共性和个性的关系，即矛盾晋性和特殊性的关系。正确答案是co\"}, {\"id\": 44, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 28, \"stem\": \"“一个志在有大成就的人，他必须知道限制自己。反之，那些什么事都想做的人，其实什么事都不能做，而终归于失败。”这段话告诉我们（\", \"options\": {\"A\": \"要学会分清事物矛盾的性质\", \"B\": \"要懂得对事物进行矛盾分析\", \"C\": \"要具体矛盾具体分析\", \"D\": \"要抓主要矛盾，不要平均使用力量\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 45, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 29, \"stem\": \"辩证否定的实质是“扬弃”，其基本含义是（）。．38．练习题\", \"options\": {\"A\": \"抛弃\", \"B\": \"既克服又保留\", \"C\": \"纯粹的否定\", \"D\": \"事物中好的方面和坏的方面的组合\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 46, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 30, \"stem\": \"唯物辩证法的否定之否定规律揭示了事物发展的〈\", \"options\": {\"A\": \"方向和道路\", \"B\": \"形式和状态\", \"C\": \"结构和功能\", \"D\": \"源泉和动力\"}, \"answer\": \"A\", \"explanation\": \"此题考查的知识点带有一定的综合性。唯物辩证法三大规律所揭示的内容是各不相同的：对立统一规律揭示的是事物发展的源泉和动力，量互变规律揭示的是事物存在的形式和状态，否定之否定親律揭示的是事物发展的方向和道路。所以本题正确选项为AO\"}, {\"id\": 47, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 31, \"stem\": \"把不同事物区分开来的依据是（）。\", \"options\": {\"A\": \"事物的度\", \"B\": \"事物的内在规定性\", \"C\": \"事物的属性\", \"D\": \"事物的量\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 48, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 32, \"stem\": \"部分质变是指（）。\", \"options\": {\"A\": \"质变过程中有量的扩张，在总的量变过程中有局部或阶段性的质变\", \"C\": \"量变是质变的必要准备\", \"D\": \"量变的客观性和普遍性\"}, \"answer\": \"B\", \"explanation\": \"此题考查的知识点是部分质变的内涵。部分质变分为阶段性部分质变和局部性部分质变两种形式。阶段性部分质变是指事物的根本性质未变，而比较次要的性质发生了变化，从而使事物的发展呈现阶段性。局部性部分质变是指事物全局的性质未变，而其中某些部分发生了性质的变化。正确答案是BO\"}, {\"id\": 49, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 33, \"stem\": \"“大海捞针\\\"是一种（）。\", \"options\": {\"A\": \"现实的可能性\", \"B\": \"抽象的可能性\", \"C\": \"现实性\", \"D\": \"不可能性\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 50, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 34, \"stem\": \"“如果偶然性不起任何作用的话，那么世界历史就会带着非常神秘的性质。'这一论断体现了（\", \"options\": {\"A\": \"必然性比偶然性重要\", \"B\": \"偶然性比必然性重要\", \"C\": \"偶然性对事物发展的重要作用\", \"D\": \"偶然性是科学的敌人\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是偶然性的作用。偶然性是指并非确定发生的，可以出现，可以不出现，可以这样出现或那样出现的不确定趋势。偶然性产生于非根本矛盾和外部条件。偶然性是不稳定的、暂时的、不确定的，是事物发展中的个别表现。偶然性对事物的发展不起决定作用，但是对事物的发展具有重要的影响作用。正确答案是C。\"}, {\"id\": 51, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 35, \"stem\": \"有人认为：“如果事物的表现形式和事物的本质会直接合二为一，一些科学家就都成为多余的了。\\\"这一命题（）。\", \"options\": {\"A\": \"夸大了现象和本质的区别\", \"B\": \"否认了现象和本质的区别\", \"C\": \"揭示了现象和本质的区别\", \"D\": \"夸大了现象和本质的统一\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 52, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 36, \"stem\": \"有一则箴言：溪水和岩石的斗争中，胜利的总是溪水，不是因为力量，而是因为坚持。\\\"“坚持就是胜利\\\"的哲理在于（\", \"options\": {\"A\": \"肯定中包含着否定的因素\", \"C\": \"必然性通过偶然性开辟道路\", \"D\": \"有其因必有其果\"}, \"answer\": \"B\", \"explanation\": \"围量变必然引起质变D.有其因必有其果此题考查的知识点是对质量互变规律的理解和运用。本题关键词是“坚持”和“胜利”，“坚持”是一个量的积累过程，“胜利”是坚持的结果，其所蕴含的哲理是量变达到一定程度必然引起质变（B）。选项D与题干相关，但该选项主要说明的是溪水与岩石之间的因果关系，不是“坚持就能胜利”所蕴含的哲理，属于干扰力极强的选项。所以，正确选项是\"}, {\"id\": 53, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 37, \"stem\": \"主观辩证法与客观辩证法的关系是（）。\", \"options\": {\"A\": \"反映与被反映的关系\", \"B\": \"唯心主义与唯物主义的关系\", \"C\": \"抽象与具体的关系\", \"D\": \"唯心辩证法与唯物辩证法的关系\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 54, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 38, \"stem\": \"恩格斯说'历史从哪里开始，思想进程也应当从哪里开始。而思想进程的进一步发展不过是历史过程在抽象的、理论上前后一贯的形式上的反映；这种反映是经过修正的，然而是按照现实的历史过程本身的规律修正的。\\\"这段话表明（\", \"options\": {\"A\": \"历史是由理论推演出来的\", \"B\": \"历史是理论的基础，理论是历史经过修正的再现\", \"C\": \"历史进程与逻辑进程是完全一致的\", \"D\": \"理论反映的是历史过程的全部内容\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 55, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 39, \"stem\": \"从抽象上升到具体的思维方法的逻辑起点是（）。\", \"options\": {\"A\": \"客观事物\", \"B\": \"社会实践\", \"C\": \"感性认识\", \"D\": \"思维抽象\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 56, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 40, \"stem\": \"我国战国时代哲学家荀子说：“天彳亍有常，不为尧存》不为桀亡。”荀子的这句话说明了（\", \"options\": {\"A\": \"社会规律的客观性\", \"B\": \"规律的平等性\", \"C\": \"规律是可以认识的\", \"D\": \"规律的能动作用\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 57, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 41, \"stem\": \"社会规律和自然规律的区别在于（）。\", \"options\": {\"A\": \"是否具有客观性\", \"B\": \"是否具有强制性\", \"C\": \"是否具有稳定性\", \"D\": \"是否能够离开人类的实践活动而存在\"}, \"answer\": \"D\", \"explanation\": \"／此题考查的知识点是自然规律和社会规律的区别。只要是规律，就有客观性、稳定性和强制性的特点。社会规律不同于自然规律之处在于，其必须通过人们有意识有目的的实践体现出来，离开了人类的实践活动，即脱离了人类社会，社会规律将无法存在，而自然规律可以脱离人类社会而存在。所以，正确选项是DO\"}, {\"id\": 58, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 42, \"stem\": \"马克思说：人在“劳动过程结束时得到的结果，在这个过程开始时就已经在劳动者的表象中存在着，即已经观念地存在着。\\\"人的活动的整个过程，就是围绕着“观念地存在着\\\"的目标和蓝图而进行的。这说明了（\", \"options\": {\"A\": \"人比动物具有更好的记忆力0意识具有能动作用\", \"B\": \"观念的作用是不能够忽略的\", \"D\": \"人的劳动过程的特殊性\"}, \"answer\": \"C\", \"explanation\": \".观念的作用是不能够忽略的D.人的劳动过程的特殊性〔解析此题考查的知识点是意识的能动作用。从马克思的这句话中可以看出：在人的意识中，不仅预先规定了活动的目标，而且为实现这一目标又预先规定了活动的方式和步骤。这就是同一定的目的性相联系的活动的计划性，从而体现了意识的能动作用。正确选项是\"}, {\"id\": 59, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 43, \"stem\": \"由于社会历史是由有意识有目的活动着的人创造的，因此（）。\", \"options\": {\"A\": \"社会规律是由人所创造的\", \"B\": \"人们可以改造或者消灭社会规律\", \"C\": \"社会发展规律只能通过人的自觉活动起作用人的活动都体现社会规律\", \"D\": \"人的活动都体现社会规律\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是社会发展的规律性和人的自觉活动。社会规律是通过人的活动表现的，社会历史发展具有客观规律性、必然性和因果制约性。A项的错误在于社会规律不是由人所创造的，它否认了社会规律的客观性。B项的错误在于人不能改造或者消灭规律。D项的错误在于并非所有人的活动都体现社会规律。正确答案是CO\"}, {\"id\": 60, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 44, \"stem\": \"对感性材料“去粗取精、去伪存真、由此及彼、由表及里的改造制作功夫”，说明意识具有（）。\", \"options\": {\"A\": \"目的性和计划性c能动创造性\", \"B\": \"对生理活动的控制作用\", \"D\": \"指导实践改造世界的作用\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是意识能动作用的表现，是一道理解性试题，难度较大。四个选项都是意识能动作用的表现，但是只有AC两个选项与题干有关。本题考查的核心是对感性材料的“改造制作功夫”，这是典型的创造性的体现，只有创造性才能“改造制作”。同时，对感性材料加工制作的过程，也就是由感性认识上升到理性认识，由认识现象到认识本质的过程。而这一过程也恰好说明意识具有能动创造性。因而C选项正确。很多考生将题干的核心单纯地放在了“去粗取精、去伪存真，由此及彼、由表及里”的目的性上，因而会误认为A选项正确。B选项，对生理活动的调节在题干中没有体现，故不选。D选项，指导实践改造世界也与题干无关，题干所说是从感性认识上升为理性认识，还在认识范围内，还没有指导实践，所以也不能选。\"}, {\"id\": 61, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 45, \"stem\": \"客观规律性与主观能动性统一的基础是（）。\", \"options\": {\"A\": \"实践\", \"B\": \"规律\", \"C\": \"意识\", \"D\": \"人\"}, \"answer\": \"A\", \"explanation\": \"B，规律c.意识此题考查的知识点是乖是客观规律性与主观能动性统一的基础。尊重事物发展的规律与发挥人的主观能动性是辩证统一的。而实践是客观规律性与主观能动性统一的基础。所以本题选AO\"}, {\"id\": 62, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 46, \"stem\": \"中国跨过资本主义发展阶段直接进入社会主义社会后，在社会主义建设问题上，中国人民经过反复实践和探索，又走上了建设中国特色社会主义的成功之路。这一事实说\", \"options\": {\"A\": \"社会历史规律具有决定作用\", \"B\": \"主体的选择可以不受社会历史规律的制约\", \"C\": \"在社会历史发展问题上，主体没有选择的自由\", \"D\": \"社会发展是历史决定性与主体选择性的有机统一\"}, \"answer\": \"D\", \"explanation\": \"此题考查的知识点是社会历史趋向与主体选择的关系。社会历史发展具有规律性，但并不因此而否定主体人在可能性空间内的选择。题干中“跨过”和“中国特色社会主义”表明主体选择在社会发展中的作用。选项A正确，但与题意不符。选项BC本身就是错昃的。所以，本题的正确选项是DO\"}, {\"id\": 63, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 47, \"stem\": \"中国古代哲学家荀子说：“心不在焉，则白黑在前而目不见，雷鼓在侧而耳不闻。”这段话表明人的意识具有（）。\", \"options\": {\"A\": \"客观性\", \"C\": \"对象性\", \"D\": \"任意性\"}, \"answer\": \"B\", \"explanation\": \"埸能动性C.对象性D.任意性此题考查的知识点是意识的能动作用。“心不在焉”强调的是意识的能动作用。所以只有B是符合题意的正确选项。．思想政治工亻乍人员晋升职称台理论考试复习材料\"}, {\"id\": 64, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 48, \"stem\": \"相信“意念移物\\\"，甚至相信可以用意念来直接改变物质结构，就是（\", \"options\": {\"A\": \"主张精神主宰客观物质世界的主观唯心论\", \"B\": \"主张精神是脱离人脑独立存在的客观唯心论\", \"C\": \"认为人的思想是特殊物质的机械唯物主义\", \"D\": \"认为人具有主观能动性的实践唯物主义\"}, \"answer\": \"A\", \"explanation\": \"此题考查的知识点是主观唯心主义和客观唯心主义的区别。题干指的是主观唯心主义对意识能动作用的夸大。所以A是符合题意的正确选项。\"}, {\"id\": 65, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 49, \"stem\": \"《坛经》中记载：“时有风吹幡动，一僧曰风动，一僧曰幡动，议论不已·惠能进曰：不是风动，不是幡动，仁者心动·”这段话表明惠能关于运动的基本观点是（）·\", \"options\": {\"A\": \"运动是物质的根本属性\", \"B\": \"运动与物质是不可分割的\", \"C\": \"精神运动是物质运动的一种形式\", \"D\": \"精神是运动的主体\"}, \"answer\": \"D\", \"explanation\": \"．运动与物质是不可分割的D.精神是运动的主体此题考查的知识点是物质和运动的关系。物质和运动是不可分割的。一方面，运动是物质的存在方式和根本属性，物质是运动着的物质，脱离运动的物质是不存在的，想不运动的物质。．將导致形而上学另一方面，物质是一切运动变化和发展过程的实在基础和承担者，世界上没有离开物质的运动，任何形式的运动都有它的物质主体，设想无物质的运动，将导致唯心主义。惠能所说即是精神的运动，属于唯心主义运动观。所以选项D是符合题意的正确选项。ABC是唯物主义的运动观，是正确说法，但不符合题意。\"}, {\"id\": 66, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 50, \"stem\": \"实践高于（理论的）认识，是因为实践具有（）。\", \"options\": {\"A\": \"普遍性\", \"B\": \"绝对性\", \"C\": \"客观实在性\", \"D\": \"直接现实性\"}, \"answer\": \"D\", \"explanation\": \"[解析}此题考查的知识点是实践的基本特征。实践是物质性的活动，具有直接现实也构成实践活动的要素都是可感知的客观实在，实践的结果都是客观的，实践的水平、广度、深度和发展过程，都受着客观条件的制约和客观规律的支配。因此，实践是同主观认识活动相区别的感性物质活动。实践高于理论的认识就在于实践具有直接现实性。实践可以把主观的东西变为客观的东西，用客观同认识加以比较，就能检验出理论的认识是否具有真理性。所以只有D是正确选项。\"}, {\"id\": 67, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 51, \"stem\": \"列宁对辩证唯物主义物质范畴的定义是通过（）。\", \"options\": {\"A\": \"物质与意识的关系界定的\", \"B\": \"个别与一般的关系界定的\", \"C\": \"哲学与具体科学的关系界定的\", \"D\": \"认识与实践的关系界定的\"}, \"answer\": \"B\", \"explanation\": \".个别与一般的关系界定的D.认识与实践的关系界定的此题考查的知识点是马克思主义物质观。马克思主义哲学从物质与惹识的辩证关系上，对物质概念作出了全面的科学的规定。列宁指出：“物质是标志客观实在的哲学范畴，这种客观实在是人感觉到的，它不依赖于我们的感觉而存在，为我们的感觉所复写、摄影、反映。”可见，列宁是从物质与意识的关系上来把握物质的。物质的唯一特性是客观实在性，它存在于人的意识之外，可以为人的意识所反映。A是正确选项。\"}, {\"id\": 68, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 52, \"stem\": \"\\\"运动应当从它的反面即从静止找到它的量度\\\"，因为静止是（）。\", \"options\": {\"A\": \"运动的根本属性和存在方式\", \"B\": \"过去运动的结果和未来运动的出发点\", \"C\": \"运动的原因和根据\", \"D\": \"运动的基础和承担者\"}, \"answer\": \"B\", \"explanation\": \"此题考查的知识点是运动和为祉一，静止是运动的特殊状态，静止是相对的有条件的，是间断性和连续性的统一，是过去运动的结果和未来运动的出发点。所以只有B选项是正确选项。\"}, {\"id\": 69, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 53, \"stem\": \"先有工程设计图，然后施工建成大厦·这一事实说明（\", \"options\": {\"A\": \"意识产生物质\", \"B\": \"意识转化为物质\", \"C\": \"意识决定物质\", \"D\": \"意识创造物质\"}, \"answer\": \"B\", \"explanation\": \"此题考查的知识点是物质和意识的关系以及意识的能动性。ACD选项明显属于唯心主义观点，是错误选项。工程设计图体现了意识活动的目的性和计划性，通过施工实践把意识活动的目的性和计划性转化为现实。转化的关键是实践环节。意识的能动作用是在物质的决定作用的前提下进行的。所以只有B选项是正确选项。\"}, {\"id\": 70, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 54, \"stem\": \"“人不能两次踏进同一条河流\\\"和“人一次也不能踏进同一条河流·”这两种说法\", \"options\": {\"A\": \"都是辩证法的观点\", \"B\": \"都是诡辩论的观点\", \"C\": \"前者是辩证法的观点，后者是诡辩论的观点\", \"D\": \"前者是诡辩论的观点，后者是辩证法的观点\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是运动和静止的关系。\\\"人不能两次踏进同一条河流\\\"是古希腊哲学家赫拉克利特提出的辩证法的观点；\\\"人一次也不能踏进同一条河流\\\"是其弟子克拉底鲁提出的，是夸大绝对运动否定相对静止所导致的相对主义诡辩论观点。所以只有C选项是正确选项。\"}, {\"id\": 71, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 55, \"stem\": \"唯物辩证法的是扌旨（）。\", \"options\": {\"A\": \"一切前后相继的现象之间的联系\", \"B\": \"一切同时并存的现象之间的联系\", \"C\": \"引起和被引起的现象之间的联系\", \"D\": \"反映和被反映的现象之间的联系0思想政治工亻乍人员晋升职称政氵台理论考试复习材料\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是唯物辩证法基本范畴中的原因和结果。原因是引起一定现象的现象，结果是被引起的现象。只有这迴垣这引帥关系因果爹。因果联系一定是前后相继的，但是前后相继的联系，并不都是因果联系，只有引起和被引起的才是，所以A项是错误的；同时并存的现象没有前后相继的特点，肯定不是因果联系，所以，B项是错误的；D项反映和被反映的联系不是因果联系，所以，D项也是错误的。\"}, {\"id\": 72, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 56, \"stem\": \"区分事物发展过程中量变和质变的根本标志是（）。\", \"options\": {\"A\": \"事物的变化是否迅速\", \"B\": \"事物的变化过程中是否有部分质变\", \"C\": \"事物的变化是否超过度的范围\", \"D\": \"事物的变化是否显著\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是量变质变规律。任何事物都是质和量的统一体，作为质和量之统一的度，就是事物保持自己质的量的限度、范围。量变和质变是事物发展变化的两种形式，量变和质变各有不同的特点，然而，只有事物的变化是否超出度的范围，才是区分量变和质变的根本标志。所以，只有c项才是正确的答案。\"}, {\"id\": 73, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 57, \"stem\": \"哲学上的物质范畴与自然科学上的物质范畴的关系是（）。\", \"options\": {\"A\": \"本原和派生的关系\", \"B\": \"普遍和特殊的关系\", \"C\": \"本质和现象的关系\", \"D\": \"形式和内容的关系\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 74, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 58, \"stem\": \"辩证唯物主义认为事物发展的规律是（）。\", \"options\": {\"A\": \"思维对事物本质的概念和反映\", \"B\": \"用来整理感性材料的思维形式\", \"C\": \"事物内在的本质的必然的稳定的联系\", \"D\": \"事物联系和发展的基本环节\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是规律的含义。规律是事物运动发展过程中本质的、必然的、稳定的联系。故选项c正确。A是理性认识的含义。B是康德的唯心主义观点。D是“范畴\\\"的含义。\"}, {\"id\": 75, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 59, \"stem\": \"在工作中防止“过”或“不及”的关键在于（）。\", \"options\": {\"A\": \"抓住事物的主要矛盾\", \"B\": \"认识事物的量\", \"C\": \"确定事物的质\", \"D\": \"把握事物的度\"}, \"answer\": \"D\", \"explanation\": \"\"}, {\"id\": 76, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 60, \"stem\": \"在哲学史中我们可以看到，各种唯心主义派别之间的差异和矛盾，常常有利于唯物主义的发展，这一事实说明（\", \"options\": {\"A\": \"矛盾一方克服另一方促使事物发展\", \"B\": \"矛盾一方的发展可以为另一方的发展提供条件\", \"C\": \"矛盾双方中每一方的自身矛盾，可以为另一方的发展所利用\", \"D\": \"矛盾双方的融洽促使事物发展\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是矛盾的同一性和斗争性在事物发展中的作用。由于矛盾双方相互依存、互为存在的条件，矛盾双方可以利用对方的发展使自己获得发展；矛盾同一性使对立双方相互利用，相互吸引对方有利于自身的因素而得到发展；矛盾双方的内在同一性规定着事物转化的可能和发展的基本趋势。ABD项不是矛盾同一性和斗争性在事物发展中的作用，是错误选项；只有c项符合矛盾同一性和斗争性在事物发展中的作用。\"}, {\"id\": 77, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 61, \"stem\": \"事物内部的肯定方面和否定方面的对立统一运动，从表现形式上看〈）。\", \"options\": {\"A\": \"是事物自我完善和发展的过程\", \"B\": \"是新事物战胜旧事物的过程0一是螺旋式上升或波浪式前进的过程\", \"D\": \"是不断周而复始的循环过程\"}, \"answer\": \"C\", \"explanation\": \"解析〕此题考查的知识点是否定之否定规律。否定之否定规律揭示了事物发展的方向和道路，是事物的发展呈现出螺旋式上升或波浪式前进的总趋势。只有C选项是符合否定之否定规律的正确选项。\"}, {\"id\": 78, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 62, \"stem\": \"孔子在《论语》中讲到：\\\"出门如见大宾，使民如承大祭。己所不欲，勿施于人。\\\"己所不欲，勿施于人\\\"所蕴含的哲理是（）。\", \"options\": {\"A\": \"矛盾的同一性和斗争性\", \"B\": \"矛盾的普遍性和特殊性\", \"C\": \"主要矛盾和次要矛盾\", \"D\": \"内部矛盾和外部矛盾\"}, \"answer\": \"A\", \"explanation\": \"B，矛盾的普遍性和特殊性D.内部矛盾和外部矛盾此题考查的知识点是矛盾的基本属性同一性和斗争性。“己所不欲，勿施于人”所体现的哲理就是要善于从对立面的角度看问题，即从对立中把握同一，从同一中把握对立。即矛盾的同一性和斗争性原理。\"}, {\"id\": 79, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 63, \"stem\": \"．动者恒动，静者恒静。”这一说法属于（）。\", \"options\": {\"A\": \"辩证法的观点\", \"B\": \"形而上学的观点\", \"C\": \"诡辩论的观点\", \"D\": \"唯心主义的观点\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 80, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 64, \"stem\": \"“庖丁解牛”“游刃有余\\\"“揠苗助长”“苗枯田荒\\\"，它们的共同启示是（),\", \"options\": {\"A\": \"现象是规律的外在表现形式C／尊重规律是取得成功的基础\", \"B\": \"人在规律面前是无能为力的\", \"D\": \"解放思想是取得成功的条件\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 81, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 65, \"stem\": \"如果要开一张包治百病的药方，或者拟定一个适用于一切情况的一般准则，那是很荒谬的。因为这种做法违背了（\", \"options\": {\"A\": \"任何事物都包含矛盾的原理\", \"B\": \"不同的矛盾用不同方法解决的原理\", \"C\": \"事物之间普遍联系的原理\", \"D\": \"特殊性中包含着普遍性的原理\"}, \"answer\": \"B\", \"explanation\": \"\"}, {\"id\": 82, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 66, \"stem\": \"我们党统一战线中的“又斗争又联合\\\"的策略和在改革开放中坚持“对外开放和独立自主、自力更生相统一”的方针的哲学依据是（）。\", \"options\": {\"A\": \"否定之否定规律对立统一规律\", \"B\": \"事物发展的过程论\", \"D\": \"质量互变规律\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 83, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 67, \"stem\": \"在人与世界的相互作用中，人与世界同时得到了改变，并获得日益丰富的内容·造成这一变化的基础是（）。\", \"options\": {\"A\": \"自然界自身的运动人的实践活动\", \"B\": \"人的意识的能动作用\", \"D\": \"工具的制造与使用\"}, \"answer\": \"C\", \"explanation\": \"\"}, {\"id\": 84, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 68, \"stem\": \"“忧心忡忡的穷人甚至对最美丽的风景都没有什么感觉\\\"“贩卖矿物的商人只看矿物的商业价值，他没有矿物学的感觉\\\"。这两句话（）。\", \"options\": {\"A\": \"表明人的意识不是对客观世界的反映\", \"B\": \"是主观唯心主义的观点，表明人的感觉具有主体性\", \"D\": \"是经验论的观点\"}, \"answer\": \"C\", \"explanation\": \"此题考查的知识点是意识的能动性和主体性。人与动物不同，动物被动机械地反映外界，而人则是积极主动地感觉、反映外界事物，即人具有主体差异性、主观能动性。不同的主体对同一事物由于不同的目的，在观察、感觉、反映时，其指向是不同的，因此所获得的认识也是不同的。因此，c选项正确。A选项自身表述错误；B选项，虽然因主体差异没能感受到风景和矿物的存在，但并未否认物质的存在，也未否认物质第一性，故不符合题意；D选项与题干无关。\"}, {\"id\": 85, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"单选题\", \"number\": 69, \"stem\": \"习近平总书记在党的二十大报告中指出：“坚持把国家和民族发展放在自己力量的基点上，坚持把中国发展进步的命运牢牢掌握在自己手中。\\\"这一论断蕴含的哲理是内因是事物发展变化的根据，决定着事物发展的基本趋势\", \"options\": {\"B\": \"人们在自己选定的条件下创造历史，要发扬历史主动精神\", \"C\": \"量变是质变的必要准备，质变是量变的必然结果\", \"D\": \"新事物在本质上优越于旧事物，具有强大生命力\"}, \"answer\": \"A\", \"explanation\": \"\"}, {\"id\": 86, \"section\": \"（二）世界的物质性及其发展规律\", \"type\": \"多选题\", \"number\": 1, \"stem\": \"思维和存在的关系问题之所以是哲学的基本问题，其原因包括（\", \"options\": {\"A\": \"该问题是人类认识和改造世界不能回避的最基本问题\", \"B\": \"该问题是划分哲学中基本派别的依据\", \"C\": \"该问题是人类实际生活中的基本问题\", \"D\": \"该问题决定着人们思想和行动的出发点与方向\"}, \"answer\": \"ABCD\", \"explanation\": \"本题考查思维与存在关系问题作为哲学基本问题的原因或者说依据。该知识点是马克思主义基本原理第二章的一个基本内容。只需基本的记忆与理解，该题就可做对。\"}];\n(function(){\nvar quizState={filtered:[],currentIdx:0,mode:'sequential',answers:{},showReview:false};\nALL_Q.forEach(function(q,i){q._uid=i});\n\nfunction init(){\nvar sections=[],sel=document.getElementById('section-filter');\nALL_Q.forEach(function(q){var s=q.section.trim();if(sections.indexOf(s)===-1)sections.push(s)});\nsections.forEach(function(s){var o=document.createElement('option');o.value=s;o.textContent=s.length>25?s.substr(0,25)+'...':s;sel.appendChild(o)});\nsel.addEventListener('change',applyFilter);\ndocument.getElementById('btn-sequential').addEventListener('click',function(){setMode('sequential')});\ndocument.getElementById('btn-random').addEventListener('click',function(){setMode('random')});\ndocument.getElementById('btn-reset').addEventListener('click',resetProgress);\ndocument.getElementById('btn-review').addEventListener('click',toggleReview);\ndocument.getElementById('btn-prev').addEventListener('click',prevQuestion);\ndocument.getElementById('btn-next').addEventListener('click',nextQuestion);\ndocument.addEventListener('keydown',function(e){if(e.key==='ArrowRight'||e.key==='ArrowDown'){e.preventDefault();nextQuestion()}if(e.key==='ArrowLeft'||e.key==='ArrowUp'){e.preventDefault();prevQuestion()}});\napplyFilter();renderQuestion();updateStats()\n}\n\nfunction applyFilter(){\nvar sel=document.getElementById('section-filter');\nquizState.filtered=sel.value==='all'?ALL_Q.slice():ALL_Q.filter(function(q){return q.section.trim()===sel.value});\nquizState.currentIdx=0;renderQuestion();updateStats()\n}\n\nfunction setMode(m){\nquizState.mode=m;\ndocument.getElementById('btn-sequential').classList.toggle('active',m==='sequential');\ndocument.getElementById('btn-random').classList.toggle('active',m==='random');\nquizState.currentIdx=0;\nif(m==='random')shuffleFiltered();\nrenderQuestion()\n}\n\nfunction shuffleFiltered(){\nvar a=quizState.filtered;\nfor(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t}\n}\n\nfunction resetProgress(){quizState.answers={};quizState.currentIdx=0;if(quizState.mode==='random')shuffleFiltered();renderQuestion();updateStats()}\n\nfunction toggleReview(){quizState.showReview=!quizState.showReview;document.getElementById('review-panel').style.display=quizState.showReview?'block':'none';if(quizState.showReview)renderReview()}\n\nfunction getAns(q){var n=q.number;if(!quizState.answers[n])quizState.answers[n]={selected:[],correct:false,seen:false};return quizState.answers[n]}\n\nfunction escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;')}\n\nfunction renderQuestion(){\nvar area=document.getElementById('question-area'),list=quizState.filtered;\nif(list.length===0){area.innerHTML='<div class=\"empty-state\">该章节暂无题目</div>';return}\nif(quizState.currentIdx>=list.length)quizState.currentIdx=list.length-1;\nif(quizState.currentIdx<0)quizState.currentIdx=0;\nvar q=list[quizState.currentIdx],ans=getAns(q),opts=q.options||{},isMulti=q.type==='多选题',submitted=ans.seen;\nvar h='<div class=\"q-card\">';\nh+='<div class=\"q-meta\"><span class=\"badge '+(isMulti?'multi':'single')+'\">'+(isMulti?'多选题':'单选题')+'</span><span>#'+q.number+'</span><span>'+(q.section.length>22?q.section.substr(0,22)+'...':q.section)+'</span></div>';\nh+='<div class=\"q-stem\">'+escH(q.stem)+'</div><div class=\"q-options\">';\nvar keys=Object.keys(opts).sort(),selL=ans.selected||[];\nfor(var i=0;i<keys.length;i++){\nvar k=keys[i],v=opts[k],cls='q-option';\nif(submitted)cls+=' disabled';\nif(selL.indexOf(k)!==-1)cls+=' selected';\nif(submitted&&q.answer&&q.answer.indexOf(k)!==-1)cls+=' correct-ans';\nif(submitted&&selL.indexOf(k)!==-1&&q.answer&&q.answer.indexOf(k)===-1)cls+=' wrong-ans';\nh+='<div class=\"'+cls+'\" data-opt=\"'+k+'\" onclick=\"selectOption(this,\\''+k+'\\')\"><span class=\"opt-label\">'+k+'</span><span>'+escH(v)+'</span></div>';\n}\nh+='</div>';\nif(submitted){\nvar ok=ans.correct;\nh+='<div class=\"q-feedback show '+(ok?'correct':'wrong')+'\"><div class=\"exp-title\">'+(ok?' 回答正确！':' 回答错误，正确答案是 '+(q.answer||'暂无'))+'</div>';\nif(q.explanation)h+='<div style=\"margin-top:6px\">'+escH(q.explanation)+'</div>';\nh+='</div>';\n}else if(isMulti){h+='<div class=\"q-submit\"><button id=\"btn-submit\" onclick=\"submitMulti()\">提交答案</button></div>'}\nh+='</div>';area.innerHTML=h;\ndocument.getElementById('btn-prev').disabled=quizState.currentIdx===0;\ndocument.getElementById('btn-next').disabled=quizState.currentIdx>=list.length-1;\nvar total=list.length,done=Object.values(quizState.answers).filter(function(a){return a.seen}).length;\ndocument.getElementById('progress-text').textContent='第 '+(quizState.currentIdx+1)+'/'+total+' 题';\ndocument.getElementById('progress-pct').textContent=total>0?Math.round(done/total*100)+'%':'0%';\ndocument.getElementById('progress-fill').style.width=total>0?(done/total*100)+'%':'0%';\nupdateStats()\n}\n\nwindow.selectOption=function(el,letter){\nvar q=quizState.filtered[quizState.currentIdx],ans=getAns(q);\nif(ans.seen)return;\nif(q.type==='多选题'){var idx=ans.selected.indexOf(letter);if(idx===-1){ans.selected.push(letter);el.classList.add('selected')}else{ans.selected.splice(idx,1);el.classList.remove('selected')}}\nelse{var all=document.querySelectorAll('.q-option');all.forEach(function(o){o.classList.remove('selected')});el.classList.add('selected');ans.selected=[letter];submitSingle(letter)}\n};\n\nfunction submitSingle(l){var q=quizState.filtered[quizState.currentIdx],ans=getAns(q);ans.seen=true;ans.correct=(q.answer===l);renderQuestion()}\n\nwindow.submitMulti=function(){var q=quizState.filtered[quizState.currentIdx],ans=getAns(q);if(ans.selected.length===0)return;ans.seen=true;var s=ans.selected.sort().join(''),a=(q.answer||'').split('').sort().join('');ans.correct=(s===a);renderQuestion()};\n\nfunction nextQuestion(){if(quizState.currentIdx<quizState.filtered.length-1){quizState.currentIdx++;renderQuestion()}}\nfunction prevQuestion(){if(quizState.currentIdx>0){quizState.currentIdx--;renderQuestion()}}\n\nfunction updateStats(){\nvar all=Object.values(quizState.answers),seen=all.filter(function(a){return a.seen}),ok=seen.filter(function(a){return a.correct});\ndocument.getElementById('stat-total').textContent=seen.length;\ndocument.getElementById('stat-correct').textContent=ok.length;\ndocument.getElementById('stat-wrong').textContent=seen.length-ok.length;\ndocument.getElementById('stat-score').textContent=seen.length>0?Math.round(ok.length/seen.length*100)+'%':'-'\n}\n\nfunction renderReview(){\nvar list=document.getElementById('review-list'),wrong=quizState.filtered.filter(function(q){var a=quizState.answers[q.number];return a&&a.seen&&!a.correct});\nif(wrong.length===0){document.getElementById('review-empty').style.display='block';list.innerHTML='';return}\ndocument.getElementById('review-empty').style.display='none';\nvar h='';wrong.forEach(function(q){h+='<div class=\"review-item\" onclick=\"jumpToQ('+q.number+')\"><span class=\"q-num\">#'+q.number+'</span>'+escH(q.stem.substr(0,50))+(q.stem.length>50?'...':'')+'<span class=\"q-correct\">正确答案: '+(q.answer||'-')+'</span></div>'});\nlist.innerHTML=h\n}\n\nwindow.jumpToQ=function(n){var l=quizState.filtered;for(var i=0;i<l.length;i++){if(l[i].number===n){quizState.currentIdx=i;quizState.showReview=false;document.getElementById('review-panel').style.display='none';renderQuestion();window.scrollTo({top:0,behavior:'smooth'});return}}};\n\ninit()\n})();\n</script>\n</body>\n</html>"}]}